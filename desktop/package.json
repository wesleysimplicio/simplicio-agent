{
  "name": "simplicio-desktop",
  "version": "1.8.0",
  "description": "Simplicio Agent — Seu assistente pessoal que realmente se importa",
  "main": "electron/main.cjs",
  "author": "Wesley Simplicio <plasmatoid@gmail.com>",
  "license": "Proprietary",
  "scripts": {
    "start": "electron .",
    "dev": "concurrently -k \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1 --port 5174",
    "dev:electron": "wait-on http://127.0.0.1:5174 && electron .",
    "build": "electron-vite build",
    "stage:runtime": "node scripts/stage-runtime-bin.cjs",
    "build:mac": "npm run stage:runtime && vite build && electron-builder build --mac --config",
    "build:win": "npm run stage:runtime && vite build && electron-builder build --win --config",
    "build:linux": "npm run stage:runtime && vite build && electron-builder build --linux --config",
    "dist:mac": "npm run stage:runtime && electron-vite build && electron-builder build --mac --config",
    "dist:win": "npm run stage:runtime && electron-vite build && electron-builder build --win --config",
    "dist:linux": "npm run stage:runtime && electron-vite build && electron-builder build --linux --config",
    "dist:all": "npm run build",
    "test": "npm run test:renderer && npm run test:electron",
    "test:renderer": "vitest run",
    "test:electron": "node --test electron/*.test.cjs"
  },
  "build": {
    "appId": "com.simplicio.agent",
    "productName": "Simplicio Agent",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/bin",
        "to": "bin"
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "entitlements": "electron/entitlements.mac.plist",
      "entitlementsInherit": "electron/entitlements.mac.inherit.plist",
      "hardenedRuntime": true,
      "gatekeeperAssess": false
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "msi",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "rpm",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "build/icon.ico"
    },
    "dmg": {
      "artifactName": "Simplicio-Agent-${version}-${arch}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "wesleysimplicio",
      "repo": "simplicio-agent"
    }
  },
  "dependencies": {
    "@assistant-ui/react": "0.12.28",
    "@assistant-ui/react-streamdown": "^0.1.11",
    "@audiowave/react": "^0.6.2",
    "@chenglou/pretext": "^0.0.6",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/language": "^6.12.4",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@lezer/highlight": "^1.2.3",
    "@nanostores/react": "^1.1.0",
    "@nous-research/ui": "^0.13.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@remotion/bundler": "^4.0.481",
    "@remotion/cli": "^4.0.481",
    "@remotion/player": "^4.0.0",
    "@remotion/renderer": "^4.0.481",
    "@simplicio/shared": "file:../apps/shared",
    "@streamdown/code": "^1.1.1",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.4",
    "@tanstack/react-query": "^5.100.6",
    "@tanstack/react-virtual": "^3.13.24",
    "@vscode/codicons": "^0.0.45",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "dnd-core": "^14.0.1",
    "electron-updater": "^6.6.2",
    "fflate": "^0.8.3",
    "hast-util-from-html-isomorphic": "^2.0.0",
    "hast-util-to-text": "^4.0.2",
    "ignore": "^7.0.5",
    "katex": "^0.16.45",
    "leva": "^0.10.1",
    "motion": "^12.38.0",
    "nanostores": "^1.3.0",
    "node-pty": "1.1.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-arborist": "^3.5.0",
    "react-dnd-html5-backend": "^14.0.3",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.17.0",
    "react-shiki": "^0.9.3",
    "remark-math": "^6.0.0",
    "remend": "^1.3.0",
    "remotion": "^4.0.0",
    "shiki": "^4.0.2",
    "simple-git": "^3.36.0",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.4",
    "tw-shimmer": "^0.4.11",
    "unicode-animations": "^1.0.3",
    "unified": "^11.0.5",
    "unist-util-visit-parents": "^6.0.2",
    "use-stick-to-bottom": "^1.1.6",
    "vfile": "^6.0.3",
    "web-haptics": "^0.0.6"
  },
  "devDependencies": {
    "@electron/asar": "^3.2.0",
    "@eslint/js": "^9.39.4",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/hast": "^3.0.4",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.8.1",
    "electron-vite": "*",
    "eslint": "^9.39.4",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.8.3",
    "rcedit": "^5.0.2",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "overrides": {
    "@assistant-ui/store": "0.2.13"
  }
}
